#!/usr/bin/env php
<?php declare(strict_types=1);

// Locate the autoloader — support both standalone and monorepo-embedded installs.
$autoloadCandidates = [
    __DIR__ . '/../autoload.php',
    __DIR__ . '/../../autoload.php',
    __DIR__ . '/../third_party/autoload.php',
    __DIR__ . '/../../third_party/autoload.php',
    __DIR__ . '/../../../autoload.php',
    __DIR__ . '/../../../third_party/autoload.php',
];

$autoloaded = false;
foreach ($autoloadCandidates as $candidate) {
    if (file_exists($candidate)) {
        require $candidate;
        $autoloaded = true;
        break;
    }
}

if (!$autoloaded) {
    fwrite(STDERR, "Composer autoloader not found. Run 'composer install' first.\n");
    exit(1);
}

use Symfony\Component\Console\Application;
use Webkernel\StdGit\StdGit;
use Webkernel\XMonorepo\Commands\DiscoverCommand;
use Webkernel\XMonorepo\Commands\SplitCommand;
use Webkernel\XMonorepo\Commands\StatusCommand;
use Webkernel\XMonorepo\Commands\StatsCommand;

use Webkernel\XMonorepo\XMonorepo;

$root = function_exists('webapp_path') ? webapp_path() : getcwd();
$configPath = rtrim($root, '/\\') . '/x-monorepo.php';

if (!file_exists($configPath)) {
    fwrite(STDERR, "Required x-monorepo config not found: {$configPath}\n");
    fwrite(STDERR, "Create this project config explicitly; package defaults are not used.\n");
    exit(1);
}

$config = require $configPath;

if (!is_array($config)) {
    fwrite(STDERR, "x-monorepo config must return an array: {$configPath}\n");
    exit(1);
}

$xMonorepo = (new XMonorepo(new StdGit()))
    ->withConfig($configPath)
    ->dotGitRoot((string) ($config['monorepo_root'] ?? $root));

$app = new Application('x-monorepo', '1.0.0');
$app->add(new DiscoverCommand($xMonorepo));
$app->add(new SplitCommand($xMonorepo));
$app->add(new StatusCommand($xMonorepo));
$app->add(new StatsCommand($xMonorepo));

exit($app->run());
